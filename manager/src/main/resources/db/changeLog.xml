<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.0.xsd
        http://www.liquibase.org/xml/ns/dbchangelog-ext https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <changeSet id="1" author="jerome">
        <createTable tableName="profile">
            <column name="id" type="varchar">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="version" type="bigint"/>
            <column name="username" type="varchar"/>
            <column name="fullname" type="varchar"/>
            <column name="email" type="varchar"/>
        </createTable>
        <addUniqueConstraint columnNames="username"
                             constraintName="const_username"
                             tableName="profile"/>
        <createTable tableName="store">
            <column name="id" type="varchar">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="type" type="varchar"/>
            <column name="owner" type="varchar"/>
            <column name="name" type="varchar"/>
            <column name="creationdate" type="bigint"/>
            <column name="usage" type="float"/>
            <column name="status" type="varchar"/>
            <column name="log" type="clob"/>
        </createTable>
    </changeSet>

    <!-- Multi-Store Support: Permettre plusieurs stores par utilisateur -->
    <changeSet id="2" author="victor">
        <comment>Add unique constraint on owner+name to support multiple stores per user</comment>
        <addUniqueConstraint
            tableName="store"
            columnNames="owner, name"
            constraintName="uk_store_owner_name"/>
        <createIndex tableName="store" indexName="idx_store_owner_name">
            <column name="owner"/>
            <column name="name"/>
        </createIndex>
    </changeSet>

    <!-- Multi-Server Support: Track which server hosts each store -->
    <changeSet id="3" author="victor">
        <comment>Add serverId column to store table for multi-server deployment</comment>
        <addColumn tableName="store">
            <column name="serverid" type="varchar(255)"/>
        </addColumn>
        <createIndex tableName="store" indexName="idx_store_serverid">
            <column name="serverid"/>
        </createIndex>
    </changeSet>

    <!-- Multi-Server Replication: Allow same store name on different servers -->
    <changeSet id="4" author="victor">
        <comment>Change unique constraint to (owner, name, serverId) to support store replication across servers</comment>
        <dropUniqueConstraint tableName="store" constraintName="uk_store_owner_name"/>
        <addUniqueConstraint tableName="store"
            columnNames="owner, name, serverid"
            constraintName="uk_store_owner_name_server"/>
    </changeSet>

</databaseChangeLog>
